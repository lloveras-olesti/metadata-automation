# Secrets — never commit
.env

# Client data — never commit
data/master_urls.csv
data/pilot_sample.csv
data/write_log.csv
data/write_errors.csv
data/geo_pages_backup.csv
data/*.csv
data/menus/*.html
data/lookups/*.csv
data/screaming-frog/*.csv

# Keep empty dirs tracked
!data/screaming-frog/.gitkeep
!data/lookups/.gitkeep
!data/menus/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
.python-version
