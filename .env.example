# ============================================================
# auto-metadata — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# PrestaShop Webservice credentials
PRESTASHOP_API_KEY=your_api_key_here
PRESTASHOP_BASE_URL=https://www.yoursite.com

# PrestaShop language IDs — run verify_prestashop.py to discover these
# The script will print all language IDs and their ISO codes.
PRESTASHOP_LANG_ID_ES=1
PRESTASHOP_LANG_ID_CA=2

# Anthropic API key (used by generate_ai_titles.py and generate_category_meta.py)
ANTHROPIC_API_KEY=your_anthropic_key_here
